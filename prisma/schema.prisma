generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Maqsad {
  DEEN // الدين
  AQL // العقل
  NAFS // النفس
  NASL // النسل
  MAL // المال
}

model Invite {
  id    String     @id @default(uuid()) @db.Uuid
  token String     @unique
  type  InviteType

  school_id  String  @db.Uuid
  created_by String  @db.Uuid
  used_by    String? @db.Uuid

  is_active  Boolean   @default(true)
  use_count  Int       @default(0)
  max_uses   Int?
  expires_at DateTime?
  used_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  school  School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  creator Profile  @relation("InvitesCreatedBy", fields: [created_by], references: [id], onDelete: Restrict)
  usedBy  Profile? @relation("InviteUsedBy", fields: [used_by], references: [id], onDelete: SetNull)

  @@map("invites")
}

enum InviteType {
  TEACHER
  STUDENT
}

// One trait per Maqsad per stage (so max 5 traits per stage)
model StageTrait {
  id         String   @id @default(uuid()) @db.Uuid
  stage_id   String   @db.Uuid
  maqsad     Maqsad
  name       String // e.g. "الدراية"
  definition String // e.g. "قدرة الطالب على فهم سبب الفعل..."
  created_at DateTime @default(now())

  stage              RoadmapStage      @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  elements           TraitElement[]
  module_main_traits RoadmapModule[]   @relation("ModuleMainTrait")
  evaluations        TraitEvaluation[]

  @@unique([stage_id, maqsad]) // one trait per Maqsad per stage
  @@map("stage_traits")
}

// Assessment elements — visual guidance only, not scored individually
model TraitElement {
  id         String   @id @default(uuid()) @db.Uuid
  trait_id   String   @db.Uuid
  text       String // e.g. "يفهم الطالب لماذا يتحرك"
  order      Int
  created_at DateTime @default(now())

  trait StageTrait @relation(fields: [trait_id], references: [id], onDelete: Cascade)

  @@map("trait_elements")
}

// Link the main activating trait to a module
// Add this field to RoadmapModule:
// main_trait_id  String?  @db.Uuid
// main_trait     StageTrait? @relation("ModuleMainTrait", fields: [main_trait_id], references: [id])

// Teacher's trait evaluation after student completes a module
model TraitAssessment {
  id           String   @id @default(uuid()) @db.Uuid
  module_id    String   @db.Uuid
  student_id   String   @db.Uuid
  teacher_id   String   @db.Uuid
  general_note String?
  submitted_at DateTime @default(now())
  updated_at   DateTime @updatedAt

  module       RoadmapModule     @relation(fields: [module_id], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)
  teacher      Teacher           @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  trait_scores TraitEvaluation[]

  @@unique([module_id, student_id]) // one assessment per student per module, but updatable
  @@map("trait_assessments")
}

// One score row per trait inside the assessment
model TraitEvaluation {
  id            String   @id @default(uuid()) @db.Uuid
  assessment_id String   @db.Uuid
  trait_id      String   @db.Uuid
  score         Float // e.g. 42.0 out of 50 for main, or 8.0 out of 12.5 for others
  note          String?
  created_at    DateTime @default(now())

  assessment TraitAssessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  trait      StageTrait      @relation(fields: [trait_id], references: [id], onDelete: Cascade)

  @@unique([assessment_id, trait_id]) // one score per trait per assessment
  @@map("trait_evaluations")
}

model Profile {
  id                           String              @id @db.Uuid
  created_at                   DateTime            @default(now())
  full_name                    String
  role                         Role
  reviewed_assessment_attempts AssessmentAttempt[] @relation("AssessmentReviewedBy")
  managed_school               School?             @relation("SchoolAdmin")
  student                      Student?
  teacher                      Teacher?
  posts                        Post[]
  post_reactions               PostReaction[]
  avatar_url                   String?
  avatar_path                  String?
  created_invites              Invite[]            @relation("InvitesCreatedBy")
  used_invites                 Invite[]            @relation("InviteUsedBy")

  @@map("profiles")
}

model School {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String              @unique
  admin_id           String?             @unique @db.Uuid
  created_at         DateTime            @default(now())
  language           String              @default("ar")
  description        String?
  slug               String              @unique @default("")
  color_bg           String              @default("#0B0B0C")
  color_primary      String              @default("#ac8e52")
  color_secondary    String              @default("#E5B93C")
  announcements      Announcement[]
  assessmentAttempts AssessmentAttempt[]
  assessments        Assessment[]
  classes            Class[]
  quizzes            Quiz[]
  roadmap            Roadmap?
  admin              Profile?            @relation("SchoolAdmin", fields: [admin_id], references: [id])
  students           Student[]
  teachers           Teacher[]
  posts              Post[]
  invites            Invite[]

  @@map("schools")
}

model Teacher {
  id               String            @id @default(uuid()) @db.Uuid
  created_at       DateTime          @default(now())
  profile_id       String            @unique @db.Uuid
  school_id        String            @db.Uuid
  announcements    Announcement[]
  classes          Class[]
  quizzes          Quiz[]
  profile          Profile           @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  school           School            @relation(fields: [school_id], references: [id], onDelete: Cascade)
  traitAssessments TraitAssessment[]

  @@map("teachers")
}

model Student {
  id                  String                  @id @default(uuid()) @db.Uuid
  class_id            String?                 @db.Uuid
  created_at          DateTime                @default(now())
  onboarding_status   StudentOnboardingStatus @default(PENDING_INTAKE)
  profile_id          String                  @unique @db.Uuid
  school_id           String?                 @db.Uuid
  assessment_attempts AssessmentAttempt[]
  moduleAttempts      ModuleAttempt[]
  quiz_attempts       QuizAttempt[]
  class               Class?                  @relation(fields: [class_id], references: [id])
  profile             Profile                 @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  school              School?                 @relation(fields: [school_id], references: [id])
  traitAssessments    TraitAssessment[]

  @@map("students")
}

model Class {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  created_at         DateTime            @default(now())
  school_id          String              @db.Uuid
  teacher_id         String?             @db.Uuid
  announcements      Announcement[]
  assessmentAttempts AssessmentAttempt[]
  school             School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teacher            Teacher?            @relation(fields: [teacher_id], references: [id])
  quizzes            Quiz[]
  students           Student[]

  @@unique([school_id, name])
  @@map("classes")
}

model Announcement {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  school_id  String   @db.Uuid
  class_id   String   @db.Uuid
  teacher_id String   @db.Uuid
  created_at DateTime @default(now())
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model Quiz {
  id         String         @id @default(uuid()) @db.Uuid
  name       String
  school_id  String         @db.Uuid
  class_id   String         @db.Uuid
  teacher_id String         @db.Uuid
  created_at DateTime       @default(now())
  attempts   QuizAttempt[]
  questions  QuizQuestion[]
  class      Class          @relation(fields: [class_id], references: [id], onDelete: Cascade)
  school     School         @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teacher    Teacher        @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model QuizQuestion {
  id             String       @id @default(uuid()) @db.Uuid
  quiz_id        String       @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime     @default(now())
  answers        QuizAnswer[]
  options        QuizOption[]
  quiz           Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizOption {
  id          String       @id @default(uuid()) @db.Uuid
  question_id String       @db.Uuid
  text        String
  order       Int
  created_at  DateTime     @default(now())
  question    QuizQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("quiz_options")
}

model QuizAttempt {
  id           String       @id @default(uuid()) @db.Uuid
  quiz_id      String       @db.Uuid
  student_id   String       @db.Uuid
  score        Int?
  total        Int?
  submitted_at DateTime     @default(now())
  answers      QuizAnswer[]
  quiz         Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([quiz_id, student_id])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id          String       @id @default(uuid()) @db.Uuid
  attempt_id  String       @db.Uuid
  question_id String       @db.Uuid
  answer      String
  is_correct  Boolean?
  created_at  DateTime     @default(now())
  attempt     QuizAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    QuizQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model Assessment {
  id         String               @id @default(uuid()) @db.Uuid
  title      String
  type       AssessmentType
  school_id  String?              @db.Uuid
  is_active  Boolean              @default(true)
  created_at DateTime             @default(now())
  attempts   AssessmentAttempt[]
  questions  AssessmentQuestion[]
  school     School?              @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model AssessmentQuestion {
  id             String             @id @default(uuid()) @db.Uuid
  assessment_id  String             @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime           @default(now())
  answers        AssessmentAnswer[]
  options        AssessmentOption[]
  assessment     Assessment         @relation(fields: [assessment_id], references: [id], onDelete: Cascade)

  @@map("assessment_questions")
}

model AssessmentOption {
  id          String             @id @default(uuid()) @db.Uuid
  question_id String             @db.Uuid
  text        String
  order       Int
  created_at  DateTime           @default(now())
  question    AssessmentQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("assessment_options")
}

model AssessmentAttempt {
  id                 String                 @id @default(uuid()) @db.Uuid
  assessment_id      String                 @db.Uuid
  student_id         String                 @db.Uuid
  score              Int?
  total              Int?
  review_status      AssessmentReviewStatus @default(PENDING)
  reviewer_id        String?                @db.Uuid
  reviewer_notes     String?
  assigned_school_id String?                @db.Uuid
  assigned_class_id  String?                @db.Uuid
  submitted_at       DateTime               @default(now())
  reviewed_at        DateTime?
  answers            AssessmentAnswer[]
  assessment         Assessment             @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  assigned_class     Class?                 @relation(fields: [assigned_class_id], references: [id])
  assigned_school    School?                @relation(fields: [assigned_school_id], references: [id])
  reviewer           Profile?               @relation("AssessmentReviewedBy", fields: [reviewer_id], references: [id])
  student            Student                @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@map("assessment_attempts")
}

model AssessmentAnswer {
  id          String             @id @default(uuid()) @db.Uuid
  attempt_id  String             @db.Uuid
  question_id String             @db.Uuid
  answer      String
  is_correct  Boolean?
  created_at  DateTime           @default(now())
  attempt     AssessmentAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    AssessmentQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("assessment_answers")
}

model Roadmap {
  id         String         @id @default(uuid()) @db.Uuid
  school_id  String         @unique @db.Uuid
  title      String         @default("بنك الأسئلة")
  created_at DateTime       @default(now())
  stages     RoadmapStage[]
  school     School         @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@map("roadmaps")
}

model RoadmapStage {
  id         String          @id @default(uuid()) @db.Uuid
  roadmap_id String          @db.Uuid
  title      String
  order      Int
  created_at DateTime        @default(now())
  modules    RoadmapModule[]
  roadmap    Roadmap         @relation(fields: [roadmap_id], references: [id], onDelete: Cascade)
  traits     StageTrait[]

  @@map("roadmap_stages")
}

model RoadmapModule {
  id               String            @id @default(uuid()) @db.Uuid
  stage_id         String            @db.Uuid
  title            String
  description      String?
  order            Int
  created_at       DateTime          @default(now())
  stage            RoadmapStage      @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  contents         ModuleContent[]
  questions        RoadmapQuestion[]
  attempts         ModuleAttempt[]
  main_trait_id    String?           @db.Uuid
  main_trait       StageTrait?       @relation("ModuleMainTrait", fields: [main_trait_id], references: [id])
  traitAssessments TraitAssessment[]

  @@map("roadmap_modules")
}

model ModuleContent {
  id           String        @id @default(uuid()) @db.Uuid
  module_id    String        @db.Uuid
  type         ContentType
  order        Int
  body         String?
  storage_path String?
  image_url    String?
  alt_text     String?
  video_url    String?
  video_title  String?
  created_at   DateTime      @default(now())
  module       RoadmapModule @relation(fields: [module_id], references: [id], onDelete: Cascade)

  @@map("module_contents")
}

model RoadmapQuestion {
  id             String                  @id @default(uuid()) @db.Uuid
  module_id      String                  @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime                @default(now())
  module         RoadmapModule           @relation(fields: [module_id], references: [id], onDelete: Cascade)
  options        RoadmapQuestionOption[]
  matching_pairs MatchingPair[]
  answers        ModuleAnswer[]

  @@map("roadmap_questions")
}

model RoadmapQuestionOption {
  id          String          @id @default(uuid()) @db.Uuid
  question_id String          @db.Uuid
  text        String
  order       Int
  question    RoadmapQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("roadmap_question_options")
}

model MatchingPair {
  id          String          @id @default(uuid()) @db.Uuid
  question_id String          @db.Uuid
  left        String
  right       String
  order       Int
  question    RoadmapQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("matching_pairs")
}

model ModuleAttempt {
  id         String         @id @default(uuid()) @db.Uuid
  module_id  String         @db.Uuid
  student_id String         @db.Uuid
  score      Int
  total      Int
  passed     Boolean
  created_at DateTime       @default(now())
  module     RoadmapModule  @relation(fields: [module_id], references: [id], onDelete: Cascade)
  student    Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)
  answers    ModuleAnswer[]

  @@unique([module_id, student_id])
  @@map("module_attempts")
}

model ModuleAnswer {
  id          String          @id @default(uuid()) @db.Uuid
  attempt_id  String          @db.Uuid
  question_id String          @db.Uuid
  answer      String
  is_correct  Boolean
  attempt     ModuleAttempt   @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    RoadmapQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("module_answers")
}

model Post {
  id          String   @id @default(uuid()) @db.Uuid
  school_id   String   @db.Uuid
  author_id   String   @db.Uuid // profile.id
  content     String? // text (nullable if image only)
  image_url   String? // Supabase Storage public URL
  image_path  String? // Supabase Storage path (for deletion)
  reply_to_id String?  @db.Uuid // null = top-level post
  created_at  DateTime @default(now())

  school    School         @relation(fields: [school_id], references: [id], onDelete: Cascade)
  author    Profile        @relation(fields: [author_id], references: [id], onDelete: Cascade)
  reply_to  Post?          @relation("PostReplies", fields: [reply_to_id], references: [id], onDelete: Cascade)
  replies   Post[]         @relation("PostReplies")
  reactions PostReaction[]

  @@map("posts")
}

model PostReaction {
  id        String       @id @default(uuid()) @db.Uuid
  post_id   String       @db.Uuid
  author_id String       @db.Uuid
  type      ReactionType

  post   Post    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author Profile @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@unique([post_id, author_id]) // one reaction per user per post
  @@map("post_reactions")
}

enum ReactionType {
  LIKE
  LOVE
  DISLIKE
  HAHA
  SAD
}

enum Role {
  OWNER
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MCQ
  TF
  WRITTEN
  MATCHING
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
}

enum StudentOnboardingStatus {
  PENDING_INTAKE
  INTAKE_SUBMITTED
  SCHOOL_ASSIGNED
  SCHOOL_PLACEMENT_SUBMITTED
  CLASS_ASSIGNED
}

enum AssessmentType {
  PLATFORM_INTAKE
  SCHOOL_PLACEMENT
}

enum AssessmentReviewStatus {
  PENDING
  REVIEWED
}
